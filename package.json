{
	"name": "react-native-country-state-city-picker",
	"version": "0.1.0",
	"description": "Country, state, and city picker for React Native",
	"main": "./lib/module/index.js",
	"types": "./lib/typescript/src/index.d.ts",
	"exports": {
		".": {
			"source": "./src/index.tsx",
			"types": "./lib/typescript/src/index.d.ts",
			"default": "./lib/module/index.js"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"src",
		"lib",
		"!**/__tests__",
		"!**/__fixtures__",
		"!**/__mocks__",
		"!**/.*"
	],
	"scripts": {
		"example": "bun --filter react-native-country-state-city-picker-example start",
		"build": "bob build",
		"clean": "del-cli lib",
		"prepare": "bob build && husky",
		"typecheck": "tsc --project tsconfig.test.json",
		"lint": "eslint \"**/*.{js,ts,tsx}\"",
		"format": "prettier --write \"**/*.{js,ts,tsx,json,md}\"",
		"format:check": "prettier --check \"**/*.{js,ts,tsx,json,md}\"",
		"check": "bun run typecheck && bun run lint && bun run format:check",
		"test": "jest",
		"test:e2e": "maestro test e2e/",
		"changeset": "changeset",
		"version": "changeset version",
		"release": "bun run build && changeset publish"
	},
	"keywords": [
		"react-native",
		"ios",
		"android",
		"expo",
		"country",
		"state",
		"city",
		"picker",
		"select",
		"dropdown",
		"cascade",
		"address",
		"location",
		"country-picker",
		"state-picker",
		"city-picker",
		"country-select",
		"address-form",
		"geocoded",
		"typescript",
		"accessible",
		"dark-mode",
		"headless",
		"new-architecture",
		"bottom-sheet"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/shankulkarni/react-native-country-state-city-picker.git"
	},
	"author": "Shan Kulkarni <shan.kulkarni.ts@gmail.com> (https://github.com/shankulkarni)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/shankulkarni/react-native-country-state-city-picker/issues"
	},
	"homepage": "https://github.com/shankulkarni/react-native-country-state-city-picker#readme",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"devDependencies": {
		"@changesets/cli": "^2.31.0",
		"@eslint/compat": "^2.0.3",
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@jest/types": "^30.3.0",
		"@react-native/babel-preset": "0.85.0",
		"@react-native/eslint-config": "0.85.0",
		"@react-native/eslint-plugin": "^0.85.2",
		"@react-native/jest-preset": "^0.85.2",
		"@testing-library/jest-native": "^5.4.3",
		"@testing-library/react-native": "^13.3.3",
		"@types/jest": "^30.0.0",
		"@types/react": "^19.2.0",
		"@typescript-eslint/eslint-plugin": "^8.59.1",
		"@typescript-eslint/parser": "^8.59.1",
		"babel-jest": "^30.3.0",
		"del-cli": "^7.0.0",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-eslint-comments": "^3.2.0",
		"eslint-plugin-ft-flow": "^3.0.11",
		"eslint-plugin-jest": "^29.15.2",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.1.1",
		"eslint-plugin-react-native": "^5.0.0",
		"husky": "^9",
		"jest": "^30.3.0",
		"jest-environment-jsdom": "^30.3.0",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"react": "19.2.0",
		"react-native": "0.83.6",
		"react-native-builder-bob": "^0.41.0",
		"react-test-renderer": "19.2.0",
		"turbo": "^2.8.21",
		"typescript": "^6.0.2"
	},
	"peerDependencies": {
		"react": ">=18.0.0",
		"react-native": ">=0.76.0"
	},
	"workspaces": [
		"example"
	],
	"react-native-builder-bob": {
		"source": "src",
		"output": "lib",
		"targets": [
			[
				"module",
				{
					"esm": true
				}
			],
			[
				"typescript",
				{
					"project": "tsconfig.build.json"
				}
			]
		]
	},
	"prettier": {
		"singleQuote": true,
		"semi": false,
		"trailingComma": "es5",
		"useTabs": true
	},
	"lint-staged": {
		"*.{js,ts,tsx}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md}": [
			"prettier --write"
		]
	},
	"create-react-native-library": {
		"type": "library",
		"languages": "js",
		"tools": [
			"eslint"
		],
		"version": "0.62.0"
	}
}
